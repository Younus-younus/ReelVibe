# ─── Database ───────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=reelvibe
DB_PORT=3306

# ─── App ────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key

# ─── Razorpay ────────────────────────────────────────────
# Sign up free at https://razorpay.com → Settings → API Keys → Generate Test Key
# Use TEST keys (key_id starts with rzp_test_) for development; no real money charged
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE
